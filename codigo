#Assume that all trajectories start at an altitude 35 ft above the airport reference elevation.

import math
import matplotlib.pyplot as plt

# Constantes (SI)
g = 9.80665
FT_TO_M = 0.3048

DT = 1.0

# ISA simple (devuelve rho en kg/m3)

def isa_rho(h_m):
    T0 = 288.15
    p0 = 101325.0
    L = 0.0065
    R = 287.05

    if h_m < 0:
        h_m = 0.0

    # troposfera hasta 11 km
    if h_m <= 11000.0:
        T = T0 - L * h_m
        p = p0 * (T / T0) ** (g / (R * L))
        rho = p / (R * T)
        return rho

    # por encima (isoterma simple)
    T11 = T0 - L * 11000.0
    p11 = p0 * (T11 / T0) ** (g / (R * L))
    p = p11 * math.exp(-g * (h_m - 11000.0) / (R * T11))
    rho = p / (R * T11)
    return rho



